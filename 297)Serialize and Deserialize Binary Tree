class Codec:


    def serialize(self, root):
        res=[]
        def preorder(root):
            if root is None:
                res.append("NULL")
                return
            res.append(str(root.val))
            preorder(root.left)
            preorder(root.right)
        preorder(root)   
        return ",".join(res)
       
        """Encodes a tree to a single string.
        
        :type root: TreeNode
        :rtype: str
        """
        

    def deserialize(self, data):
        self.i=0
        data=data.split(",")
        def preorder():
            if data[self.i] == "NULL":
                self.i+=1
                return None
            root = TreeNode(int(data[self.i]))
            self.i+=1
            root.left=preorder()
            root.right=preorder()
            return root
        return preorder()
        """Decodes your encoded data to tree.
        
        :type data: str
        :rtype: TreeNode
        """
            
             
        
