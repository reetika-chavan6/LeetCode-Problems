class Solution(object):
    def majorityElement(self, nums):
        majority={}
        maxElem=0
        for i in nums:
            majority[i]=majority.get(i,0) + 1  #m[key]=value
        maxCount=0
        for j in majority:
            if majority[j]>maxCount:   #value>count
                maxCount=majority[j] #count
                maxElem=j #key
        return maxElem
