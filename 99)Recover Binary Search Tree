class Solution(object):
    def recoverTree(self, root):
        f,s,p=None,None,None
        def inorder(root):
            nonlocal f, s, p   
    
            if root:
                inorder(root.left)
                if p and p.val>root.val:
                    if not f:
                        f=p
                    s=root
                p=root
                inorder(root.right)
        inorder(root)
        f.val,s.val=s.val,f.val
        return root
